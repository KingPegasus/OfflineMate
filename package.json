{
  "name": "offline-assistant",
  "private": true,
  "version": "1.0.0",
  "description": "OfflineMate is a privacy-first, context-aware mobile assistant built with Expo and React Native.\r The app is designed to run fully on-device (LLM, retrieval, speech, and tools) and support a wide\r range of phones from low-end to flagship devices through adaptive model tiers.",
  "main": "expo-router/entry",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "prepare": "husky",
    "validate": "npm run typecheck && npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:perf && npm audit --audit-level=high",
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:perf": "vitest run tests/perf",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:coverage": "vitest run --coverage tests/unit tests/integration tests/e2e",
    "android:logs": "adb logcat -s ReactNativeJS:V ReactNative:V Expo:V",
    "android:logs:all": "adb logcat",
    "android:logs:raw": "adb logcat *:V",
    "website:build": "node scripts/minify-website.mjs",
    "search:live": "tsx scripts/run-web-search.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "expo": {
    "install": {
      "exclude": [
        "react"
      ]
    }
  },
  "dependencies": {
    "@fugood/react-native-audio-pcm-stream": "^1.1.4",
    "@tanstack/react-query": "^5.90.21",
    "buffer": "^6.0.3",
    "chrono-node": "^2.9.0",
    "expo": "^55.0.5",
    "expo-alarm": "^0.2.2",
    "expo-asset": "~55.0.8",
    "expo-calendar": "^55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-contacts": "^55.0.8",
    "expo-dev-client": "~55.0.11",
    "expo-device": "^55.0.9",
    "expo-file-system": "^55.0.10",
    "expo-keep-awake": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-notifications": "^55.0.11",
    "expo-router": "^55.0.4",
    "expo-secure-store": "^55.0.8",
    "expo-speech": "~55.0.8",
    "expo-sqlite": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.4",
    "react-native": "0.83.2",
    "react-native-device-info": "^15.0.2",
    "react-native-executorch": "^0.7.2",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "^4.2.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.2",
    "whisper.rn": "^0.5.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "html-minifier-terser": "^7.2.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "husky": "^9.1.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
