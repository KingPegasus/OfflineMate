{
  "name": "offline-assistant",
  "private": true,
  "version": "1.0.0",
  "description": "OfflineMate is a privacy-first, context-aware mobile assistant built with Expo and React Native.\r The app is designed to run fully on-device (LLM, retrieval, speech, and tools) and support a wide\r range of phones from low-end to flagship devices through adaptive model tiers.",
  "main": "expo-router/entry",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "prepare": "husky",
    "validate": "npm run typecheck && npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:perf && npm audit --audit-level=high",
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:perf": "vitest run tests/perf",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:coverage": "vitest run --coverage tests/unit tests/integration tests/e2e",
    "android:logs": "adb logcat -s ReactNativeJS:V ReactNative:V Expo:V",
    "android:logs:all": "adb logcat",
    "android:logs:raw": "adb logcat *:V",
    "website:build": "node scripts/minify-website.mjs",
    "search:live": "tsx scripts/run-web-search.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.20.2"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@fugood/react-native-audio-pcm-stream": "^1.1.4",
    "@tanstack/react-query": "^5.100.9",
    "buffer": "^6.0.3",
    "chrono-node": "^2.9.1",
    "expo": "~56.0.3",
    "expo-alarm": "^0.2.2",
    "expo-asset": "~56.0.13",
    "expo-calendar": "~56.0.8",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.14",
    "expo-contacts": "~56.0.7",
    "expo-dev-client": "~56.0.14",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-keep-awake": "~56.0.3",
    "expo-linking": "~56.0.11",
    "expo-notifications": "~56.0.12",
    "expo-router": "~56.2.5",
    "expo-secure-store": "~56.0.4",
    "expo-speech": "~56.0.3",
    "expo-splash-screen": "~56.0.9",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-device-info": "^15.0.2",
    "react-native-executorch": "^0.8.4",
    "react-native-executorch-expo-resource-fetcher": "^0.8.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-mmkv": "^4.3.0",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.1",
    "react-native-worklets": "0.8.3",
    "whisper.rn": "^0.5.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-preset-expo": "~56.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "html-minifier-terser": "^7.2.0",
    "husky": "^9.1.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.2"
  }
}
